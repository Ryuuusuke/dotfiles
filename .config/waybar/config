{
  "margin-top" : 5,
    "margin-left": 10,
    "margin-right": 10,
    "height" : 30,
    "modules-left": [
      "hyprland/window"
    ],
    "modules-center": [
      "hyprland/workspaces",
    ],
    "modules-right": [
    "custom/wallpaper", 
    "pulseaudio",
    "network",
    "temperature",
    "battery",
    "clock",
    ],
    "hyprland/window": {
      "format": "{}",
      "max-length": 35,
      "rewrite": {
        "": "Harsh"
      },
      "separate-outputs": true,
    },
    "hyprland/workspaces": {
      "format": "{icon}",
      "on-click": "activate",
      "format-icons": {
        "active": "пДС ",
      },
      "sort-by-number": true,
      "persistent-workspaces": {
        "*": 4, // 5 workspaces by default on every monitor
        "HDMI-A-1": 3 // but only three on HDMI-A-1
      },
    },

    "clock": {
      "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
      "format-alt": "{:%Y-%m-%d}"
    },
    "cpu": {
      "format": "  {usage}%",
      "tooltip": false
    },
    "memory": {
      "format": "{}% пГЙ "
    },

    "temperature": {
      "critical-threshold": 80,
      "format": "{icon} {temperatureC}¬∞C",
      "format-icons": ["пЭЂ", "пЛЙ", "пЭ©"]
    },
    "battery": {
      "states": {
        "warning": 30,
        "critical": 15
      },
      "format": "{icon}  {capacity}%",
      "format-full": "{icon}  {capacity}%",
      "format-charging": "пЧІ  {capacity}%",
      "format-plugged": "пЗ¶  {capacity}%",
      "format-alt": "{time} {icon}",
      "format-icons": ["пЙД", "пЙГ", "пЙВ", "пЙБ", "пЙА"]
    },
    "network": {
      "format-wifi": "пЗЂ  {signalStrength}%",
      "format-ethernet": "{cidr} пЮЦ",
      "tooltip-format": "{ifname} via {gwaddr} пЮЦ",
      "format-linked": "{ifname} (No IP) пЮЦ",
      "format-disconnected": " вЪ† ",
      "format-alt": "{ifname}: {ipaddr}/{cidr}"
    },
    "pulseaudio": {
      "format": "{icon}  {volume}%",
      "format-bluetooth": "{volume}% {icon}пКФ {format_source}",
      "format-bluetooth-muted": "ођ§ {icon}пКФ {format_source}",
      "format-muted": "ођ§",
      "format-icons": {
        "headphone": "пА•",
        "hands-free": "пЦР",
        "headset": "пЦР",
        "phone": "пВХ",
        "portable": "пВХ",
        "car": "пЖє",
        "default": ["пА¶", "пАІ", "пА®"]
      },
      "on-click": "pavucontrol"
    },
     "custom/wallpaper": {                                                                       "format": "ої© ",
	"on-click":"exec ~/.config/hypr/scripts/wallpaperchange.sh"  
},
}
